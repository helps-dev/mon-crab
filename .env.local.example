# Copy to .env.local and fill in after deploying CrabStaking (see /contracts).
# These are PUBLIC values (contract addresses) — safe to expose in the browser.

# CrabStaking contract address on Monad testnet
NEXT_PUBLIC_STAKING_ADDRESS=

# $CRAB token address (launched on nad.fun)
NEXT_PUBLIC_CRAB_ADDRESS=

# Wrapped MON (WMON) reward token address
NEXT_PUBLIC_WMON_ADDRESS=
